# Server
PORT=3000
NODE_ENV=development

# Postgres connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ete_tar

# Auth secrets (use long, random values in production)
JWT_SECRET=change-me-access-token-secret
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret

# Comma-separated list of origins allowed to call this API
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001

# Transactional email (password reset)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
